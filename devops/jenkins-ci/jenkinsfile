pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    app: jenkins-agent
spec:
  serviceAccountName: jenkins-ci
  automountServiceAccountToken: false
  securityContext:
    runAsNonRoot: true
    fsGroup: 1000
    seccompProfile:
      type: RuntimeDefault
  volumes:
    - name: workspace
      emptyDir: {}
    - name: tmp
      emptyDir: {}
    - name: buildkit-state
      emptyDir: {}
    - name: rootless-run
      emptyDir:
        medium: Memory
    - name: buildkit-sock
      emptyDir:
        medium: Memory
        sizeLimit: 64Mi
    - name: docker-config
      emptyDir:
        medium: Memory
    - name: trivy-cache
      persistentVolumeClaim:
        claimName: trivy-cache-pvc
  containers:
    - name: jnlp
      image: jenkins/inbound-agent:latest
      securityContext:
        runAsUser: 1000
        allowPrivilegeEscalation: false
        readOnlyRootFilesystem: true
        capabilities:
          drop: ["ALL"]
      env:
        - name: HOME
          value: /tmp
      volumeMounts:
        - name: workspace
          mountPath: /home/jenkins/agent
        - name: tmp
          mountPath: /tmp

    - name: python
      image: tarieky-api:latest
      command: ["sleep", "99d"]
      securityContext:
        runAsUser: 1000
        allowPrivilegeEscalation: false
        readOnlyRootFilesystem: true
        capabilities:
          drop: ["ALL"]
      env:
        - name: HOME
          value: /tmp
      volumeMounts:
        - name: workspace
          mountPath: /home/jenkins/agent
        - name: tmp
          mountPath: /tmp
          
    - name: sonar-scanner
      image: sonarsource/sonar-scanner-cli:latest
      command: ["sleep", "99d"]
      securityContext:
        runAsUser: 1000
        allowPrivilegeEscalation: false
        readOnlyRootFilesystem: true
        capabilities:
          drop: ["ALL"]
      env:
        - name: HOME
          value: /tmp
      volumeMounts:
        - name: workspace
          mountPath: /home/jenkins/agent
        - name: tmp
          mountPath: /tmp

    - name: buildkitd
      image: moby/buildkit:rootless
      args: ["--addr", "unix:///run/buildkit/buildkitd.sock"]
      securityContext:
        runAsUser: 1000
        seccompProfile:
          type: Unconfined
      volumeMounts:
        - name: buildkit-sock
          mountPath: /run/buildkit
        - name: buildkit-state
          mountPath: /home/user/.local/share/buildkit
        - name: tmp
          mountPath: /home/user/.local/tmp
        - name: rootless-run
          mountPath: /run/user/1000
        - name: workspace
          mountPath: /workspace
        - name: tmp
          mountPath: /tmp

    - name: buildctl
      image: moby/buildkit:rootless
      command: ["sleep", "99d"]
      securityContext:
        runAsUser: 1000
        allowPrivilegeEscalation: false
        readOnlyRootFilesystem: true
        capabilities:
          drop: ["ALL"]
      env:
        - name: HOME
          value: /tmp
      volumeMounts:
        - name: buildkit-sock
          mountPath: /run/buildkit
        - name: docker-config
          mountPath: /home/user/.docker
        - name: workspace
          mountPath: /workspace
        - name: tmp
          mountPath: /tmp

    - name: trivy
      image: aquasec/trivy:latest
      command: ["sleep", "99d"]
      securityContext:
        runAsUser: 1000
        allowPrivilegeEscalation: false
        readOnlyRootFilesystem: true
        capabilities:
          drop: ["ALL"]
      env:
        - name: HOME
          value: /tmp
      volumeMounts:
        - name: trivy-cache
          mountPath: /home/scanner/.cache/trivy
        - name: workspace
          mountPath: /workspace
        - name: tmp
          mountPath: /tmp
'''
        }
    }
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timeout(time: 30, unit: 'MINUTES')
        // Removed timestamps() because the plugin is missing from the Jenkins server
    }
    
    environment {
        DOCKER_IMAGE = 'aaboelala4/tarieky-api'
        SONARQUBE_SERVER_NAME = 'SonarQube'
        BUILDKIT_HOST = 'unix:///run/buildkit/buildkitd.sock'
        DOCKER_CONFIG = '/home/user/.docker'
        TRIVY_CACHE_DIR = '/home/scanner/.cache/trivy'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Quality & Security Checks') {
            parallel {
                stage('Testing & SAST') {
                    stages {
                        stage('Test') {
                            steps {
                                container('python') {
                                    // Dependencies are now pre-installed in the Docker image
                                    sh 'python -m coverage run --source=authentication,myapi manage.py test --verbosity=2'
                                    sh 'python -m coverage xml -o coverage.xml'
                                    sh 'python -m coverage html -d htmlcov'
                                    sh 'python -m coverage report --fail-under=70'
                                }
                            }
                            post {
                                always {
                                    container('python') {
                                        archiveArtifacts artifacts: 'coverage.xml,htmlcov/**', allowEmptyArchive: true
                                    }
                                }
                            }
                        }
                        
                        stage('SAST - SonarQube') {
                            steps {
                                container('sonar-scanner') {
                                    withSonarQubeEnv(env.SONARQUBE_SERVER_NAME) {
                                        sh 'sonar-scanner \
                                            -Dsonar.projectKey=tarieky-api \
                                            -Dsonar.sources=. \
                                            -Dsonar.python.coverage.reportPaths=coverage.xml'
                                    }
                                }
                            }
                        }
                    }
                }
                
                stage('SCA - Trivy File System Scan') {
                    steps {
                        container('trivy') {
                            sh 'trivy fs --format table -o trivy-fs-report.txt .'
                            sh 'cat trivy-fs-report.txt'
                        }
                    }
                }
            }
        }
        
        stage('Build Image') {
            steps {
                container('buildctl') {
                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'REG_USER',
                        passwordVariable: 'REG_PASS'
                    )]) {
                        sh '''
                            set -eu
                            mkdir -p "$DOCKER_CONFIG"
                            cat > "$DOCKER_CONFIG/config.json" <<EOF
                            {"auths":{"https://index.docker.io/v1/":{"auth":"$(printf "%s:%s" "$REG_USER" "$REG_PASS" | base64 -w0)"}}}
                            EOF

                            buildctl --addr "$BUILDKIT_HOST" build \\
                                --frontend dockerfile.v0 \\
                                --local context=. \\
                                --local dockerfile=. \\
                                --output type=image,name=docker.io/${DOCKER_IMAGE}:${BUILD_NUMBER},push=true \\
                                --import-cache type=registry,ref=docker.io/${DOCKER_IMAGE}:buildcache \\
                                --export-cache type=registry,ref=docker.io/${DOCKER_IMAGE}:buildcache,mode=max

                            rm -f "$DOCKER_CONFIG/config.json"
                        '''
                    }
                }
            }
        }

        stage('Trivy Scan') {
            steps {
                container('trivy') {
                    sh '''
                        set -eu
                        trivy image --cache-dir "$TRIVY_CACHE_DIR" --severity HIGH,CRITICAL --exit-code 1 docker.io/${DOCKER_IMAGE}:${BUILD_NUMBER}
                    '''
                }
            }
        }
    }
    
    post {
        
        success {
            echo "✅ Pipeline completed successfully!"
        }
        failure {
            echo "❌ Pipeline failed! Please check the logs."
        }
    }
}

